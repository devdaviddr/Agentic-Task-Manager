# Database Configuration
POSTGRES_DB=taskmanager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskmanager

# Firebase Admin SDK (Backend)
# Option 1: Provide the full service account JSON as a single environment variable
# NOTE: dotenv typically doesn't support multi-line values. Prefer Option 3 (file path) or a single-line JSON string with \n escaped.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project-id",...}'
# Option 2: Provide just the project ID (uses Application Default Credentials)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Option 3 (recommended): point to a local service account JSON file (mounted into the container)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# Option 4: supply credentials via individual env vars (use \n for newline in the private key)
# FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Environment
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Frontend
FRONTEND_URL=https://yourdomain.com
VITE_API_URL=https://your-api-domain.com

# Firebase Client SDK (Frontend)
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Logging
LOG_LEVEL=info
